---
import Layout from '../layouts/Layout.astro';
import announcementsData from '../content/announcements.json';
const announcements = announcementsData.items;
---
<Layout title="Home">
  <h1 class="mb-4">Bergen County Math League</h1>
  <div class="row g-4">
    {announcements.map((a) => (
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">{a.title}</h5>
            <h6 class="card-subtitle mb-2 text-muted">{a.date}</h6>
            <p class="card-text">{a.body}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</Layout>
