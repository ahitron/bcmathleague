---
import Layout from '../layouts/Layout.astro';
import schoolsData from '../content/schools.json';
const schools = schoolsData.items;
---
<Layout title="About">
  <h1 class="mb-2">Participating Schools</h1>
  <p class="text-muted mb-4">Schools are organized into geographic groups across Bergen County.</p>
  <div class="row g-3">
    {schools.map((g) => (
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card h-100 border-0 shadow-sm bcml-accent-top">
          <div class="card-body">
            <h2 class="h6 fw-bold text-uppercase text-bcml ls-wide mb-3">
              <i class="bi bi-geo-alt me-1"></i>Group {g.group}
            </h2>
            <ul class="list-unstyled mb-0">
              {g.schools.map((school) => (
                <li class="py-1 border-bottom small d-flex align-items-start gap-2">
                  <i class="bi bi-mortarboard text-muted mt-1" style="font-size: 0.75rem; flex-shrink: 0"></i>
                  {school}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</Layout>
