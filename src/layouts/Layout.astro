---
interface Props {
  title: string;
}
const { title } = Astro.props;
const path = Astro.url.pathname;
const currentYear = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Bergen County Math League</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style is:global>
      :root {
        --bcml-blue: #3d5a80;
        --bcml-blue-dark: #2c4066;
        --bcml-blue-light: #eef3fa;
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #f8f9fb;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      h1 {
        font-family: 'Lora', Georgia, serif;
        font-weight: 700;
      }

      main {
        flex: 1;
      }

      .navbar-bcml {
        background-color: var(--bcml-blue-dark);
      }

      .nav-link.active {
        font-weight: 600;
        color: #fff !important;
      }

      .bcml-accent-top {
        border-top: 3px solid var(--bcml-blue) !important;
      }

      .btn-bcml {
        background-color: var(--bcml-blue);
        border-color: var(--bcml-blue);
        color: #fff;
      }
      .btn-bcml:hover {
        background-color: var(--bcml-blue-dark);
        border-color: var(--bcml-blue-dark);
        color: #fff;
      }

      .badge-bcml {
        background-color: var(--bcml-blue) !important;
        color: #fff;
        text-decoration: none;
        font-size: 0.8rem;
        padding: 0.3em 0.55em;
      }
      .badge-bcml:hover {
        background-color: var(--bcml-blue-dark) !important;
        color: #fff;
      }

      .text-bcml {
        color: var(--bcml-blue) !important;
      }

      .bg-bcml-light {
        background-color: var(--bcml-blue-light) !important;
      }

      .ls-wide {
        letter-spacing: 0.07em;
      }

      .card {
        border-radius: 0.5rem;
      }

      .list-unstyled li:last-child {
        border-bottom: none !important;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-md navbar-dark navbar-bcml">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">
          <span class="d-none d-md-inline">Bergen County Math League</span>
          <span class="d-md-none">BCML</span>
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navMenu"
          aria-controls="navMenu"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class={`nav-link${path === '/' ? ' active' : ''}`} href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class={`nav-link${path === '/archive' || path === '/archive/' ? ' active' : ''}`} href="/archive">Archive</a>
            </li>
            <li class="nav-item">
              <a class={`nav-link${path === '/about' || path === '/about/' ? ' active' : ''}`} href="/about">About</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container py-4 py-md-5">
      <slot />
    </main>

    <footer class="py-3 border-top mt-auto">
      <div class="container text-center text-muted small">
        Bergen County Math League &copy; {currentYear}
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (!user) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>
